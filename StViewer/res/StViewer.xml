<?xml version="1.0" encoding="utf-8" ?>
<RegisterDescription ModelName="StViewer" VendorName="Sentech"
	ToolTip="StViewer" StandardNameSpace="None"
	SchemaMajorVersion="1" SchemaMinorVersion="1" SchemaSubMinorVersion="0"
	MajorVersion="1" MinorVersion="2" SubMinorVersion="2"
	ProductGuid="3F14564C-A8AF-4EB1-86F1-C390C9078100"
	VersionGuid="C95C49D0-F29F-436D-8839-40288451294A"
	xmlns="http://www.genicam.org/GenApi/Version_1_1"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.genicam.org/GenApi/Version_1_1
				http://www.genicam.org/GenApi/GenApiSchema_Version_1_1.xsd">

	<!-- ***************************************** -->
	<!-- RootCategory -->
	<!-- ***************************************** -->
	<Group Comment="RootCategory">
		<Category Name="Root" NameSpace="Standard">
			<Visibility>Beginner</Visibility>
			<ImposedAccessMode>RO</ImposedAccessMode>
			<pFeature>DataStream</pFeature>
		</Category>
	</Group>

	<!-- ***************************************** -->
	<!-- SubCategories -->
	<!-- ***************************************** -->
	<Group Comment="SubCategories">
		<Category Name="DataStream" NameSpace="Custom">
			<ToolTip>Data Stream.</ToolTip>
			<Description>Data Stream.</Description>
			<DisplayName>Data Stream</DisplayName>
			<Visibility>Beginner</Visibility>
			<ImposedAccessMode>RO</ImposedAccessMode>
			<pFeature>StreamBufferCountControl</pFeature>
		</Category>
		<Category Name="StreamBufferCountControl" NameSpace="Custom">
			<ToolTip>Stream Buffer Count Control.</ToolTip>
			<Description>Stream Buffer Count Control.</Description>
			<DisplayName>Stream Buffer Count Control</DisplayName>
			<Visibility>Expert</Visibility>
			<ImposedAccessMode>RO</ImposedAccessMode>
			<pFeature>StreamBufferCountMode</pFeature>
			<pFeature>StreamBufferCount</pFeature>
		</Category>
		<Category Name="TransportLayerControl" NameSpace="Standard">
			<ToolTip>Category that contains the transport Layer control features.</ToolTip>
			<Description>Category that contains the transport Layer control features.</Description>
			<DisplayName>Transport Layer Control</DisplayName>
			<Visibility>Beginner</Visibility>
			<ImposedAccessMode>RO</ImposedAccessMode>
			<pFeature>TLParamsLocked</pFeature>
		</Category>
	</Group>
 
	<!-- ***************************************** -->
	<!-- CategoryDataStrem -->
	<!-- ***************************************** -->
	<Group Comment="CategoryDataStrem">
		<Enumeration Name="StreamBufferCountMode" NameSpace="Custom">
			<ToolTip>Sets how the number of buffers used for streaming is specified.</ToolTip>
			<Description>Sets how the number of buffers used for streaming is specified.</Description>
			<DisplayName>Stream Buffer Count Mode</DisplayName>
			<Visibility>Expert</Visibility>
			<pIsLocked>TLParamsLocked</pIsLocked>
			<ImposedAccessMode>RW</ImposedAccessMode>
			<Streamable>Yes</Streamable>
			<EnumEntry Name="Automatic" NameSpace="Custom">
				<ToolTip>Automatic.</ToolTip>
				<Description>Automatic.</Description>
				<DisplayName>Automatic</DisplayName>
				<Value>0</Value>
			</EnumEntry>
			<EnumEntry Name="Manual" NameSpace="Custom">
				<ToolTip>Manual.</ToolTip>
				<Description>Manual.</Description>
				<DisplayName>Manual</DisplayName>
				<Value>1</Value>
			</EnumEntry>
			<Value>0</Value>
		</Enumeration>
		<IntSwissKnife Name="IsManual">
			<pVariable Name="MODE">StreamBufferCountMode</pVariable>
			<Formula><![CDATA[MODE <> 0]]></Formula>
			<Representation>Boolean</Representation>
		</IntSwissKnife>
		<Integer Name="StreamBufferCount">
			<ToolTip>Specifies the number of buffers to use for streaming. If you specify a large value, the actual buffer allocated may be reduced or streaming may not start.</ToolTip>
			<Description>Specifies the number of buffers to use for streaming. If you specify a large value, the actual buffer allocated may be reduced or streaming may not start.</Description>
			<DisplayName>Stream Buffer Count</DisplayName>
			<Visibility>Expert</Visibility>
			<pIsAvailable>IsManual</pIsAvailable>
			<pIsLocked>TLParamsLocked</pIsLocked>
			<ImposedAccessMode>RW</ImposedAccessMode>
			<Streamable>Yes</Streamable>
			<Value>8</Value>
			<pMin>MinStreamBufferCount</pMin>
			<pMax>MaxStreamBufferCount</pMax>
			<Representation>Linear</Representation>
		</Integer>
		<Integer Name="MinStreamBufferCount">
			<Visibility>Invisible</Visibility>
			<ImposedAccessMode>RW</ImposedAccessMode>
			<Value>5</Value>
		</Integer>
		<Integer Name="MaxStreamBufferCount">
			<Visibility>Invisible</Visibility>
			<ImposedAccessMode>RW</ImposedAccessMode>
			<Value>65535</Value>
		</Integer>
	</Group>

	<!-- ***************************************** -->
	<!-- TransportLayerControl -->
	<!-- ***************************************** -->
	<Group Comment="TransportLayerControl">
		<Integer Name="TLParamsLocked" NameSpace="Standard">
			<ToolTip>Used by the Transport Layer to prevent critical features from changing during acquisition.</ToolTip>
			<Description>Used by the Transport Layer to prevent critical features from changing during acquisition.</Description>
			<DisplayName>TL Params Locked</DisplayName>
			<Visibility>Invisible</Visibility>
			<ImposedAccessMode>RW</ImposedAccessMode>
			<Value>0</Value>
			<Min>0</Min>
			<Max>1</Max>
		</Integer>
	</Group>

	<Port Name="Device" NameSpace="Standard">
		<ToolTip>Provides the default GenICam port of the Device.</ToolTip>
		<Description>Provides the default GenICam port of the Device.</Description>
		<DisplayName>Device</DisplayName>
		<Visibility>Invisible</Visibility>
		<ImposedAccessMode>RW</ImposedAccessMode>
	</Port>
</RegisterDescription>
 