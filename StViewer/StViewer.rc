IDD_DIALOG_VIDEO_FILE DIALOGEX 0, 0, 305, 205
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CLIPCHILDREN | WS_CAPTION | WS_SYSMENU
CAPTION "Video File Configuration"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,195,183,50,14,WS_DISABLED
    PUSHBUTTON      "Cancel",IDCANCEL,247,183,50,14
    LISTBOX         IDC_LIST_FILE_NAME,55,119,244,44,LBS_SORT | LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    LTEXT           "File Name",IDC_STATIC,7,119,32,8
    PUSHBUTTON      "Add",IDC_BUTTON_ADD_FILE_NAME,247,167,50,14
END

