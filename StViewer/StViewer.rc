/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open a camera\tCtrl+O",      ID_FILE_NEW
        MENUITEM "&Load still image ...",       ID_FILE_OPEN
        MENUITEM "&Close",                      ID_FILE_CLOSE
        MENUITEM SEPARATOR
        MENUITEM "Configuration &File Setting ...", ID_FILE_CONFIGURATIONFILESETTING
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        POPUP "&Toolbars and Docking Windows"
        BEGIN
            MENUITEM "<placeholder>",               ID_VIEW_TOOLBAR
        END
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "&Interface Node ...",         ID_VIEW_INTERFACENODE
        MENUITEM "S&ystem Node ...",            ID_VIEW_SYSTEMNODE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About StViewer...",          ID_APP_ABOUT
    END
END

IDR_CAMERA_CTRL MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Open a camera\tCtrl+O",      ID_FILE_NEW
        MENUITEM "&Load still image ...",       ID_FILE_OPEN
        MENUITEM "&Close",                      ID_FILE_CLOSE
        MENUITEM "Start Acquisition",           ID_ACQ_START
        MENUITEM "Stop Acquisition",            ID_ACQ_STOP
        MENUITEM SEPARATOR
        MENUITEM "Save Still Image ...",        ID_SAVE_STILL_IMAGE
        MENUITEM "Start Recording ...",         ID_START_RECORDING
        MENUITEM "Stop Recording",              ID_STOP_RECORDING
        MENUITEM SEPARATOR
        MENUITEM "Save &Camera Config File ...", ID_FILE_SAVE_CAMERA_CONFIG_FILE
        MENUITEM "&Load Camera Config File ...", ID_FILE_LOAD_CAMERA_CONFIG_FILE
        MENUITEM SEPARATOR
        MENUITEM "Save Camera &Description File ...", ID_FILE_SAVE_CAMERA_DESCRIPTION_FILE
        MENUITEM SEPARATOR
        MENUITEM "Configuration &File Setting ...", ID_FILE_CONFIGURATIONFILESETTING
        MENUITEM SEPARATOR
        MENUITEM "Start calculating FFC correction value ...", ID_FILE_START_FFC
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        POPUP "&Toolbars and Docking Windows"
        BEGIN
            MENUITEM "<placeholder>",               ID_VIEW_TOOLBAR
        END
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM "&Interface Node ...",         ID_VIEW_INTERFACENODE
        POPUP "&Graph data source"
        BEGIN
            MENUITEM "&Registered image",           ID_GRAPHDATASOURCE_REGISTEREDIMAGE
            MENUITEM "&Converted image",            ID_GRAPHDATASOURCE_CONVERTEDIMAGE
        END
        MENUITEM "S&ystem Node ...",            ID_VIEW_SYSTEMNODE
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "&Full Screen",                ID_WINDOW_FULLSCREEN
        MENUITEM "&Cascade",                    ID_WINDOW_CASCADE
        POPUP "&Tile"
        BEGIN
            MENUITEM "&Horizontal",                 ID_WINDOW_TILE_HORZ
            MENUITEM "&Vertical",                   ID_WINDOW_TILE_VERT
        END
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About StViewer...",          ID_APP_ABOUT
    END
END

IDR_OUTPUT_POPUP MENU
BEGIN
    POPUP "Popup"
    BEGIN
        MENUITEM "&Copy",                       ID_EDIT_COPY
        MENUITEM "&Clear",                      ID_EDIT_CLEAR
    END
END

IDR_DEFECTIVE_PIXEL_DETECTION MENU
