            MENUITEM "&Registered image",           ID_GRAPHDATASOURCE_REGISTEREDIMAGE
            MENUITEM "&Converted image",            ID_GRAPHDATASOURCE_CONVERTEDIMAGE
        END
        MENUITEM "S&ystem Node ...",            ID_VIEW_SYSTEMNODE
