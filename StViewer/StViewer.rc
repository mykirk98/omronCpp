    POPUP "&Window"
    BEGIN
        MENUITEM "&Full Screen",                ID_WINDOW_FULLSCREEN
        MENUITEM "&Cascade",                    ID_WINDOW_CASCADE
        POPUP "&Tile"
        BEGIN
            MENUITEM "&Horizontal",                 ID_WINDOW_TILE_HORZ
