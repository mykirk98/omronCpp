{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build myOmronApp",
      "type": "shell",
      "command": "g++",
      "args": [
        "main.cpp",
        "CameraStaff.cpp",
        "CameraWorkerCB.cpp",
        "CameraWorker.cpp",
        "CameraManager.cpp",
        "CameraConfigurator.cpp",
        "CameraEventWorker.cpp",
        "CameraWorker_Chunk.cpp",
        "Experiment1.cpp",
        "-I/opt/sentech/include/StApi",
        "-I/opt/sentech/include/GenICam",
        "-L/opt/sentech/lib",
        "-L/opt/sentech/lib/GenICam",
        "-lStApi_C",
        "-lStApi_IP",
        "-lStApi_TL",
        "-lGCBase_gcc48_v3_4",
        "-lGenApi_gcc48_v3_4",
        "-o",
        "myOmronApp"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
