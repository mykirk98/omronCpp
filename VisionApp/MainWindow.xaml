<Window x:Class="VisionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:VisionApp.Converters"
        mc:Ignorable="d"
        Title="VisionApp" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <converters:BoolToColorConverter x:Key="BoolToColor"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: 툴바 -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="8" BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 왼쪽: 액션 버튼 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- Binding : 뷰모델의 명령과 버튼을 연결하여 MVVM 패턴을 구현하는 방식, StaticResource : 리소스 딕셔너리에 정의된 스타일이나 변환기를 참조하는 방식 -->
                    <Button Content="&#x1F50C; 자동 연결" Command="{Binding ConnectCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="&#x25B6; 운전" Command="{Binding RunCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,6,0"/>
                    <Button Content="&#x23F9; 정지" Command="{Binding StopCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,6,0"/>
                </StackPanel>
                <!-- 오른쪽: 뷰 전환 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="&#x1F4CB; 로그" Command="{Binding ToggleLogPanelCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ROW 1: 카메라 모니터링 메인 영역 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#FF1E1E1E">
            <ItemsControl ItemsSource="{Binding Cameras}" Margin="10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="8" Padding="10" CornerRadius="6" Background="#FF333337" Width="320" BorderBrush="#FF3F3F46" BorderThickness="1">
                            <StackPanel>
                                <!-- 헤더: 상태 인디케이터 + 카메라 이름 -->
                                <DockPanel Margin="0,0,0,6">
                                    <Ellipse Width="10" Height="10" Fill="{Binding IsConnected, Converter={StaticResource BoolToColor}}" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </DockPanel>
                                <!-- 이미지 프리뷰 -->
                                <Border Background="Black" Height="210" CornerRadius="3" ClipToBounds="True">
                                    <Image Source="{Binding CurrentImage}" Stretch="Uniform"/>
                                </Border>
                                <!-- FPS 정보 -->
                                <TextBlock Text="{Binding FpsDisplay}" Foreground="#FFAAAAAA" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ROW 2: 하단 로그 패널 (토글) -->
        <Border Grid.Row="2" Height="160" Background="#FF252526" BorderBrush="#FF3F3F46" BorderThickness="0,1,0,0" Visibility="{Binding IsLogPanelVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <TextBlock Text="[Log]" Foreground="#FF569CD6" FontWeight="Bold" DockPanel.Dock="Top" Margin="10,6,0,4" FontSize="12"/>
                <ListBox ItemsSource="{Binding LogEntries}" x:Name="LogListBox" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" FontFamily="Consolas" FontSize="11" Foreground="#FFCCCCCC" Margin="6,0,6,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="NoWrap">
                                <Run Text="{Binding Timestamp, StringFormat=HH:mm:ss, Mode=OneWay}" Foreground="#FF569CD6"/>    <!-- Run : TextBlock 내에서 부분적으로 스타일링된 텍스트를 표현할 때 사용 -->
                                <Run Text=" [" Foreground="#FF888888"/>
                                <Run Text="{Binding Source, Mode=OneWay}" Foreground="#FFCE9178"/> <!-- Mode : 데이터 바인딩의 방향을 지정하는 속성, OneWay : 데이터 소스에서 대상 요소로만 데이터가 흐르도록 설정 -->
                                <Run Text="] " Foreground="#FF888888"/>
                                <Run Text="{Binding Message, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
